# VizoDesk Server Environment Variables
# Copy this file to .env and fill in your values

PORT=3001

# JWT Secret — required in production (use a long random string, never commit the real value)
# Also used to encrypt per-user Gmail app passwords stored in the database.
JWT_SECRET=replace-with-long-random-secret

# Square — optional fallback when not set in the admin app (Settings → Company → Square payments)
# Paste real values locally only; never commit .env
# Access token from https://developer.squareup.com/apps (Sandbox or Production)
SQUARE_ACCESS_TOKEN=
# Location ID for Online Checkout / Payment Links (Dashboard → Locations)
SQUARE_LOCATION_ID=
# sandbox | production (omit or sandbox uses Square Sandbox API)
SQUARE_ENVIRONMENT=sandbox

# Webhook signature verification (production recommended)
# Signature key from Square app → Webhooks; notification URL must match the URL registered in Square exactly
SQUARE_WEBHOOK_SIGNATURE_KEY=
SQUARE_WEBHOOK_NOTIFICATION_URL=https://your-api.example.com/api/payments/square/webhook

# URLs — production: set these to your live admin + portal origins (https) so CORS allows the browser.
# Also set Settings → Client Portal URL in the admin app to your portal URL (stored in DB).
# PORTAL_URL is still used as a fallback for Square return URLs and CORS if Settings is empty.
PORTAL_URL=http://localhost:5174
CLIENT_URL=http://localhost:5173

# Database path (optional, defaults to ../database/vizodesk.db)
# DB_PATH=/path/to/vizodesk.db
#
# --- Render (all-in-one: see render.yaml) ---
# API Web Service: root = server. Static sites: admin + portal; VITE_API_URL = API origin ( /api optional).
# Example: CLIENT_URL=https://vizodesk-admin.onrender.com  PORTAL_URL=https://vizodesk-portal.onrender.com

# --- Hybrid: local Electron → cloud public portal (Render) ---
# Local server: after each booking create/update, POST snapshot to cloud (optional).
# Local / Electron only — POST target on Render (use /api/sync/booking or /api/public/bookings)
# CLOUD_BOOKING_SYNC_URL=https://vizodesk.onrender.com/api/sync/booking
# SYNC_SECRET — same on local + Render; or set in Settings → Company → Integrations (DB takes precedence).
# SYNC_SECRET=same-long-secret-as-on-render
#
# Render API: SYNC_SECRET required. SYNC_OWNER_USER_ID optional — if unset or invalid, sync uses first user (ORDER BY id).
#
# Render only — when clients use the public booking link on the cloud, push payment/signature updates to your studio machine:
# Use an HTTPS tunnel (ngrok, Cloudflare Tunnel, etc.) pointing at your local API, e.g. https://abc.ngrok-free.app/api/sync/callback
# LOCAL_SYNC_CALLBACK_URL=https://your-tunnel.example.com/api/sync/callback

# PDF contract uploads (optional, defaults to ../uploads at project root)
# UPLOADS_ROOT=/path/to/uploads
