# Admin SPA — copy to .env (not committed)
# API base URL the browser calls (include /api path if your server mounts there)
VITE_API_URL=http://localhost:3001/api

# Production (Render static site env), e.g.
# VITE_API_URL=https://vizodesk-api.onrender.com

# Local dev: portal Vite is fixed to port 5174 (strictPort). Override if you change it:
# VITE_PORTAL_URL=http://localhost:5174
